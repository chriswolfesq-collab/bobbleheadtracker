# Copy this file to .env.local (already gitignored) and fill in real values
# from your Supabase project's Settings > API page.

NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Shared secret guarding /api/revalidate. Must match the x-revalidate-secret
# header sent by the Supabase trigger in supabase/revalidate_trigger.sql. Set
# the real value in the Vercel project (not needed for local dev).
REVALIDATE_SECRET=any-long-random-string
